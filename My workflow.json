    {
      "parameters": {
        "jsCode": "const rows = $('Read expenses (history)').all().filter(i => Object.keys(i.json).length > 0);\nlet text;\nif (rows.length === 0) {\n  text = 'Витрат поки немає.';\n} else {\n  const last = rows.slice(-10);\n  const lines = last.map(r => `${r.json.Date || ''} — ${r.json.Amount || '0'} грн — ${r.json.Category || ''}`);\n  text = '📋 Останні витрати:\\n' + lines.join('\\n');\n}\nreturn [{ json: { text } }];"
      },
