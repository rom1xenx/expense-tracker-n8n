    {
      "parameters": {
        "jsCode": "const rows = $('Read expenses (total)').all().filter(i => Object.keys(i.json).length > 0);\nconst today = DateTime.now().setZone('Europe/Kiev').toFormat('dd.MM.yyyy');\nlet sum = 0;\nfor (const r of rows) {\n  const d = (r.json.Date || '').toString();\n  if (d.startsWith(today)) {\n    let a = (r.json.Amount == null ? '' : r.json.Amount).toString().replace(/\\s/g, '').replace(',', '.');\n    sum += parseFloat(a) || 0;\n  }\n}\nreturn [{ json: { text: `📊 Сьогодні витрачено: ${sum} грн` } }];"
      },
