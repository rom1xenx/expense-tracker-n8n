    {
      "parameters": {
        "jsCode": "const raw = ($('Telegram Trigger').item.json.message.text || '').toString();\nconst m = raw.match(/-?\\d[\\d\\s.,]*/);\nlet amount = 0;\nlet category = raw.trim();\nif (m) {\n  let numStr = m[0].replace(/\\s/g, '');\n  if (numStr.includes(',') && numStr.includes('.')) {\n    numStr = numStr.replace(/,/g, '');\n  } else if (numStr.includes(',')) {\n    numStr = numStr.replace(/,/g, '.');\n  }\n  amount = parseFloat(numStr) || 0;\n  category = raw.replace(m[0], '').trim();\n}\nif (!category) category = 'інше';\nreturn [{ json: { amount, category } }];"
      },
